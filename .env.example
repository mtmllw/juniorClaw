# OpenClaw Environment Configuration Example
# Copy this file to .env and fill in your actual API keys.

# -------------------------------------------------------------
# API KEYS (Add your provider API keys here)
# -------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=

# Default Model Selection (e.g., gpt-4o, claude-3-5-sonnet-20241022, gemini-2.5-pro)
DEFAULT_MODEL=

# -------------------------------------------------------------
# OPENCLAW GATEWAY CONFIGURATION
# -------------------------------------------------------------
# Bind the gateway to LAN so it's accessible from host browser
OPENCLAW_GATEWAY_BIND=lan

# Enable Docker Agent Sandboxing (requires /var/run/docker.sock mount)
OPENCLAW_SANDBOX=1

# Gateway Token (auto-generated by setup.sh or manually set)
OPENCLAW_GATEWAY_TOKEN=

# -------------------------------------------------------------
# GITHUB & AGENT IDENTITY CONFIGURATION
# -------------------------------------------------------------
# The GitHub token for the agent's dedicated bot account (if using PAT)
GITHUB_TOKEN=

# [OPTIONAL] GitHub App Authentication (Enterprise Grade)
# Overrides GITHUB_TOKEN if specified. Generates temporary 1-hour tokens.
GH_APP_ID=
GH_APP_INSTALLATION_ID=
GH_APP_PRIVATE_KEY_PATH=/root/.openclaw/github-app.pem
# The agent's Git commit identity
GIT_AUTHOR_NAME="OpenClaw Assistant"
GIT_AUTHOR_EMAIL="bot@yourdomain.com"
GIT_COMMITTER_NAME="OpenClaw Assistant"
GIT_COMMITTER_EMAIL="bot@yourdomain.com"
# Your personal GitHub username (to invite as a collaborator)
TARGET_GITHUB_USER=

# -------------------------------------------------------------
# TELEGRAM NOTIFICATIONS & VISUAL PROOF CONFIGURATION
# -------------------------------------------------------------
# Used by the agent to autonomously send you screenshots and test results
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -------------------------------------------------------------
# OBSERVABILITY CONFIGURATION (LANGFUSE)
# -------------------------------------------------------------
# Auto-generated by setup.sh. Used by self-hosted Langfuse server
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
LANGFUSE_ENCRYPTION_KEY=
LANGFUSE_NEXTAUTH_URL=http://localhost:3000
LANGFUSE_INIT_USER_EMAIL=admin@openclaw.local
LANGFUSE_INIT_USER_PASSWORD=

# Used by the OpenClaw agent to connect to the Langfuse server
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
